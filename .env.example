# Copy to .env for local development. Do not commit .env.

APP_ENV=local
LOG_LEVEL=INFO

# No real Gmail OAuth credentials are required for the foundation phase.
# Future Gmail credentials must be stored outside Git and loaded from environment variables or a local secret manager.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8080/oauth/callback

# Provider-neutral LLM configuration placeholder.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
OPENAI_API_KEY=

# Live Linear ProductAgent configuration placeholder.
PRODUCT_AGENT_PUBLIC_BASE_URL=
PRODUCT_AGENT_OAUTH_CLIENT_ID=
PRODUCT_AGENT_OAUTH_CLIENT_SECRET=
PRODUCT_AGENT_WEBHOOK_SECRET=
PRODUCT_AGENT_TOKEN_ENCRYPTION_KEY=
PRODUCT_AGENT_STORAGE_BACKEND=sqlite
PRODUCT_AGENT_DB_PATH=data/private/product_agent.live.sqlite3
PRODUCT_AGENT_FIRESTORE_PROJECT_ID=
PRODUCT_AGENT_FIRESTORE_DATABASE_ID=(default)
PRODUCT_AGENT_FIRESTORE_COLLECTION_PREFIX=product_agent_live
PRODUCT_AGENT_INSTALL_SCOPES=read,write,comments:create,app:assignable,app:mentionable
PRODUCT_AGENT_TEAM_NAME=Product Studio
PRODUCT_AGENT_MODEL_PROVIDER=fake
PRODUCT_AGENT_OPENAI_MODEL=gpt-5.4-mini
PRODUCT_AGENT_OPENAI_API_KEY_ENV_VAR=OPENAI_API_KEY
PRODUCT_AGENT_OPENAI_TIMEOUT_SECONDS=20
PRODUCT_AGENT_OPENAI_MAX_RETRIES=2
PRODUCT_AGENT_OPENAI_MAX_OUTPUT_TOKENS=1800

# Local persistence placeholder.
EMAIL_AGENT_DB_PATH=data/private/email_agent.local.sqlite3
